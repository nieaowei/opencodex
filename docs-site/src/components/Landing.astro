---
// Landing page shared by the three locales. Liquid Editorial composition:
// type-led centered hero, provider pill chips as content, product-as-stage
// media band, quickstart terminal, bento feature slab, docs link row.
// Styling lives in src/styles/custom.css under the `.lp` namespace.
import { Image } from 'astro:assets';
import {
	siAnthropic,
	siDeepseek,
	siGoogle,
	siMoonshotai,
	siOllama,
	siOpenrouter,
} from 'simple-icons';
import demo from '../assets/demo.gif';
import dashboard from '../assets/dashboard.png';
import picker from '../assets/codex-app-picker.png';
import heroFieldLight from '../assets/hero-field-light.png';
import heroFieldDark from '../assets/hero-field-dark.png';

interface Props {
	locale?: 'ko' | 'zh-cn';
}
const { locale } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const prefix = locale ? `${base}${locale}/` : base;

const t = (en: string, ko: string, zh: string) =>
	locale === 'ko' ? ko : locale === 'zh-cn' ? zh : en;

const icons: Record<string, string> = {
	// Lucide outline paths (24x24, stroke)
	plug: 'M12 22v-5M9 8V2M15 8V2M6 8h12l-1 6a5 5 0 0 1-10 0Z',
	key: 'M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777Zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4',
	users: 'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm13 10v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
	picker: 'M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2Zm6-2v18M3 9h6',
	bot: 'M12 8V4H8m8 0h-4M4 12a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2Zm11 3h.01M9 15h.01M2 14h2m16 0h2',
	search: 'M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm10 2-4.35-4.35',
	rocket: 'M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09ZM12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2Zm-3-3H4s.55-3.03 2-4c1.62-1.08 5 0 5 0m0 9v5s3.03-.55 4-2c1.08-1.62 0-5 0-5',
	book: 'M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20',
	code: 'M16 18l6-6-6-6M8 6l-6 6 6 6',
	folder: 'M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z',
};

// Official monochrome marks from simple-icons where the brand exists in the
// library; brands missing from it stay text-only (no generic substitutes).
const providers: { label: string; path?: string }[] = [
	{ label: 'Anthropic', path: siAnthropic.path },
	{ label: 'Google', path: siGoogle.path },
	{ label: 'xAI' },
	{ label: 'Kimi', path: siMoonshotai.path },
	{ label: 'Ollama Cloud', path: siOllama.path },
	{ label: 'Groq' },
	{ label: 'OpenRouter', path: siOpenrouter.path },
	{ label: 'Azure' },
	{ label: 'DeepSeek', path: siDeepseek.path },
	{ label: 'GLM' },
];

const quickstartMini = [
	{ cmd: 'npm install -g @bitkyc08/opencodex', note: t('Install', '설치', '安装') },
	{ cmd: 'ocx start', note: t('Start the proxy', '프록시 시작', '启动代理') },
];

const quickstart = [
	{ cmd: 'npm install -g @bitkyc08/opencodex', note: t('Install', '설치', '安装') },
	{ cmd: 'ocx init', note: t('Inject a provider into Codex', 'Codex에 프로바이더 주입', '向 Codex 注入 provider') },
	{ cmd: 'ocx start', note: t('Start the proxy', '프록시 시작', '启动代理') },
	{ cmd: 'codex "Write a hello world in Rust"', note: t('Codex now routes through ocx', 'Codex가 ocx를 경유', 'Codex 现在经由 ocx 路由') },
];

// full docs map for the closing sitemap band (also the mobile path to every section)
const docsMap = [
	{
		label: t('Getting Started', '시작하기', '开始使用'),
		icon: 'rocket',
		links: [
			{ label: t('Installation', '설치', '安装'), href: `${prefix}getting-started/installation/` },
			{ label: t('Quickstart', '빠른 시작', '快速开始'), href: `${prefix}getting-started/quickstart/` },
			{ label: t('How It Works', '동작 원리', '工作原理'), href: `${prefix}getting-started/how-it-works/` },
		],
	},
	{
		label: t('Guides', '가이드', '指南'),
		icon: 'book',
		links: [
			{ label: t('Providers', '프로바이더', '提供商'), href: `${prefix}guides/providers/` },
			{ label: t('Model Routing', '모델 라우팅', '模型路由'), href: `${prefix}guides/model-routing/` },
			{ label: t('Codex Integration', 'Codex 통합', 'Codex 集成'), href: `${prefix}guides/codex-integration/` },
			{ label: t('Codex App Model Picker', 'Codex App 모델 선택기', 'Codex App 模型选择器'), href: `${prefix}guides/codex-app-models/` },
			{ label: t('Sidecars: Search & Vision', '사이드카: 검색 & 비전', '边车：搜索与视觉'), href: `${prefix}guides/sidecars/` },
			{ label: t('Web Dashboard', '웹 대시보드', '网页控制台'), href: `${prefix}guides/web-dashboard/` },
			{ label: t('Sub-agent Surface', '서브에이전트 서피스', '子代理界面'), href: `${prefix}guides/sub-agent-surface/` },
		],
	},
	{
		label: t('Reference', '레퍼런스', '参考'),
		icon: 'code',
		links: [
			{ label: 'CLI', href: `${prefix}reference/cli/` },
			{ label: t('Configuration', '설정', '配置'), href: `${prefix}reference/configuration/` },
			{ label: t('Adapters', '어댑터', '适配器'), href: `${prefix}reference/adapters/` },
			{ label: t('Architecture', '아키텍처', '架构'), href: `${prefix}reference/architecture/` },
		],
	},
	{
		label: t('Project', '프로젝트', '项目'),
		icon: 'folder',
		links: [
			{ label: t('Contributing', '기여하기', '贡献'), href: `${prefix}contributing/` },
			{ label: 'GitHub', href: 'https://github.com/lidge-jun/opencodex' },
			{ label: 'npm', href: 'https://www.npmjs.com/package/@bitkyc08/opencodex' },
		],
	},
];
---

<div class="lp not-content">
	<!-- scene stack: hero -> quickstart -> horizontal rail. Each wrapper owns a
	     named view-timeline; its sticky inner stage pins under the pill header
	     while the next scene rides over it (motion.md sticky stacking +
	     scale-depth morph). -->
	<div class="lp-scenes">
	<section class="lp-scene lp-scene-hero">
	<div class="lp-scene-inner lp-hero-field">
		<div class="lp-field-bg" aria-hidden="true">
			<Image src={heroFieldLight} alt="" class="lp-field-light" loading="eager" widths={[1024, 2048]} sizes="100vw" />
			<Image src={heroFieldDark} alt="" class="lp-field-dark" loading="lazy" widths={[1024, 2048]} sizes="100vw" />
		</div>
		<div class="lp-hero-copy">
			<h1 id="_top">{t('Run Codex on any LLM.', 'Codex를 어떤 LLM 위에서든.', '让 Codex 跑在任意 LLM 上。')}</h1>
			<p class="lp-sub">
				{t(
					'opencodex is a local proxy that translates the Codex Responses API to any provider wire format — streaming, tool calls, reasoning, and images, in both directions. Zero Codex patches.',
					'opencodex는 Codex의 Responses API를 어떤 프로바이더 wire 포맷으로든 양방향 변환하는 로컬 프록시입니다 — 스트리밍, tool call, reasoning, 이미지까지. Codex 패치는 없습니다.',
					'opencodex 是一个本地代理，将 Codex 的 Responses API 双向翻译为任意 provider 的线路格式 —— 包括流式、工具调用、推理与图像。无需修补 Codex。'
				)}
			</p>
			<div class="lp-cta">
				<a class="lp-btn-primary" href={`${prefix}getting-started/installation/`}>
					{t('Get Started', '시작하기', '快速开始')}
					<svg viewBox="0 0 16 16" width="14" height="14" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</a>
				<a class="lp-btn-ghost" href="https://github.com/lidge-jun/opencodex">GitHub</a>
			</div>
		<ul class="lp-chips" aria-label={t('Supported providers', '지원 프로바이더', '支持的 provider')}>
				{providers.map((p) => (
					<li>
						{p.path && (
							<svg class="lp-chip-mark" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
								<path d={p.path} />
							</svg>
						)}
						{p.label}
					</li>
				))}
				<li class="lp-chip-more"><a href={`${prefix}guides/providers/`}>{t('40+ providers', '프로바이더 40+', '40+ providers')}</a></li>
			</ul>
		</div>
		<div class="lp-stage-in">
			<Image src={dashboard} alt={t(
				'The opencodex dashboard — live proxy status, routed providers, and available models',
				'opencodex 대시보드 — 실시간 프록시 상태, 라우팅된 프로바이더, 사용 가능한 모델',
				'opencodex 控制台 —— 实时代理状态、路由的 provider 与可用模型'
			)} loading="eager" />
		</div>
	</div>
	</section>

	<!-- quickstart sheet scene -->
	<section class="lp-scene lp-scene-quick">
	<div class="lp-scene-inner lp-quick">
		<div class="lp-kinetic" aria-label={t('Install. Start. Codex, rerouted.', '설치. 시작. Codex는 그대로.', '安装。启动。Codex 即刻改道。')}>
			<p class="lp-kline">{t('Install.', '설치.', '安装。')}</p>
			<p class="lp-kline">{t('Start.', '시작.', '启动。')}</p>
			<p class="lp-kline lp-kline-accent">{t('Codex, rerouted.', 'Codex는 그대로.', 'Codex 即刻改道。')}</p>
		</div>
		<div class="lp-quick-side">
			<div class="lp-terminal">
				<div class="lp-terminal-bar"><span>zsh</span></div>
				<pre>{quickstartMini.map((line) => (<code><span class="lp-prompt">$ </span>{line.cmd}<span class="lp-note">  # {line.note}</span>{'\n'}</code>))}</pre>
			</div>
			<a class="lp-inline-link" href={`${prefix}getting-started/quickstart/`}>{t('Full quickstart', '전체 퀵스타트', '完整快速开始')} →</a>
		</div>
	</div>
	</section>

	<!-- demo scrub: the capture plays through, driven by scroll -->
	<section class="lp-scene lp-scene-scrub">
	<div class="lp-scene-inner lp-scrub">
		<h2 class="lp-scrub-title">{t('Watch Codex run on a routed model.', '라우팅된 모델 위의 Codex를 그대로.', '看 Codex 跑在路由模型上。')}</h2>
		<div class="lp-scrub-stage">
			<canvas class="lp-scrub-canvas" data-base={base} data-count="158" width="960" height="856" aria-label={t('Codex App running a task on a routed non-OpenAI model', '라우팅된 비 OpenAI 모델에서 작업 중인 Codex App', 'Codex App 在路由的非 OpenAI 模型上执行任务')}></canvas>
			<Image src={demo} alt={t('Codex App running a task on a routed non-OpenAI model', '라우팅된 비 OpenAI 모델에서 작업 중인 Codex App', 'Codex App 在路由的非 OpenAI 模型上执行任务')} loading="lazy" class="lp-scrub-poster" />
		</div>
		<p class="lp-scrub-caption">{t('One task, streamed end to end through opencodex.', '작업 하나가 opencodex를 관통해 끝까지 스트리밍됩니다.', '一个任务，经 opencodex 全程流式完成。')}</p>
	</div>
	</section>
	</div>

	<!-- feature bento: dominant cell + content-weighted spans -->
	<section class="lp-bento">
		<h2 class="lp-bento-title">{t('One proxy, the whole surface.', '프록시 하나로 전체 서피스를.', '一个代理，覆盖全部能力。')}</h2>
		<div class="lp-grid">
			<article class="lp-cell lp-cell-providers">
				<h3><svg class="lp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icons.plug} /></svg>{t('Any provider', '모든 프로바이더', '任意 provider')}</h3>
				<p>
					{t(
						'Five adapters cover Anthropic Messages, Google Gemini, Azure, the OpenAI Responses passthrough, and every OpenAI-compatible Chat Completions endpoint — 40+ built-in providers.',
						'어댑터 다섯 개가 Anthropic Messages, Google Gemini, Azure, OpenAI Responses passthrough, 그리고 모든 OpenAI 호환 Chat Completions 엔드포인트를 커버합니다 — 내장 프로바이더 40+.',
						'五个适配器覆盖 Anthropic Messages、Google Gemini、Azure、OpenAI Responses passthrough，以及所有 OpenAI 兼容的 Chat Completions 端点 —— 内置 40+ provider。'
					)}
				</p>
			</article>
			<article class="lp-cell">
				<h3><svg class="lp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icons.key} /></svg>{t('OAuth or API key', 'OAuth 또는 API 키', 'OAuth 或 API key')}</h3>
				<p>{t(
					'Log in with your xAI, Anthropic, or Kimi account — auto-refreshed — forward your ChatGPT login, or paste a key.',
					'xAI, Anthropic, Kimi 계정으로 로그인(자동 갱신)하거나, ChatGPT 로그인을 포워딩하거나, 키를 붙여넣으세요.',
					'使用 xAI、Anthropic 或 Kimi 账号登录（自动刷新），转发 ChatGPT 登录，或粘贴 API key。'
				)}</p>
			</article>
			<article class="lp-cell">
				<h3><svg class="lp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icons.users} /></svg>{t('ChatGPT account pool', 'ChatGPT 계정 풀', 'ChatGPT 账号池')}</h3>
				<p>{t(
					'Existing threads keep their account; new sessions auto-route to the lowest-usage healthy one after quota refresh.',
					'기존 thread는 계정을 유지하고, 새 세션은 할당량 갱신 후 사용량이 가장 낮은 정상 계정으로 자동 라우팅됩니다.',
					'已有 thread 保持原账号；新会话在刷新额度后自动路由到用量最低的健康账号。'
				)}</p>
			</article>
			<article class="lp-cell lp-cell-picker">
				<h3><svg class="lp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icons.picker} /></svg>{t('Native in the model picker', '모델 선택기에 그대로', '原生出现在模型选择器')}</h3>
				<p>{t(
					'Routed models show up in Codex App with reasoning effort levels, next to the native ones.',
					'라우팅된 모델이 추론 강도 레벨과 함께 Codex App 선택기에 네이티브 모델과 나란히 표시됩니다.',
					'路由模型带推理强度等级出现在 Codex App 中，与原生模型并列。'
				)}</p>
				<Image src={picker} alt={t('Codex App model picker with reasoning effort levels', '추론 강도 레벨이 있는 Codex App 모델 선택기', '带推理强度等级的 Codex App 模型选择器')} loading="lazy" />
			</article>
			<article class="lp-cell">
				<h3><svg class="lp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icons.bot} /></svg>{t('Sub-agents', '서브에이전트', '子代理')}</h3>
				<p>{t(
					'Pin up to five routed or native models for Codex spawn_agent, and switch the v1 / base / v2 surface globally.',
					'Codex spawn_agent용으로 라우팅·네이티브 모델을 최대 5개 고정하고, v1 / base / v2 서피스를 전역으로 전환합니다.',
					'为 Codex spawn_agent 固定最多五个路由或原生模型，并全局切换 v1 / base / v2 界面。'
				)}</p>
			</article>
			<article class="lp-cell">
				<h3><svg class="lp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icons.search} /></svg>{t('Search & vision sidecars', '검색 & 비전 사이드카', '搜索与视觉边车')}</h3>
				<p>{t(
					'Give non-OpenAI models real web search and image understanding through a gpt-5.4-mini sidecar.',
					'gpt-5.4-mini 사이드카로 비 OpenAI 모델에 실제 웹 검색과 이미지 이해를 붙입니다.',
					'通过 gpt-5.4-mini 边车，让非 OpenAI 模型获得真实的网页搜索与图像理解能力。'
				)}</p>
			</article>
			<article class="lp-cell lp-cell-terminal">
				<h3><svg class="lp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icons.code} /></svg>{t('Quickstart', '퀵스타트', '快速开始')}</h3>
				<p>{t(
					'ocx init writes a provider into your Codex config and shares one model catalog with Codex CLI, TUI, App, and SDK. ocx stop restores native Codex cleanly.',
					'ocx init이 Codex 설정에 프로바이더를 기록하고 CLI, TUI, App, SDK가 같은 모델 카탈로그를 공유합니다. ocx stop이면 네이티브 Codex로 깔끔하게 복원됩니다.',
					'ocx init 将 provider 写入 Codex 配置，CLI、TUI、App 与 SDK 共享同一模型目录。ocx stop 可干净地恢复原生 Codex。'
				)}</p>
				<div class="lp-terminal">
					<div class="lp-terminal-bar"><span>zsh</span></div>
					<pre>{quickstart.map((line) => (<code><span class="lp-prompt">$ </span>{line.cmd}<span class="lp-note">  # {line.note}</span>{'\n'}</code>))}</pre>
				</div>
			</article>
		</div>
	</section>

	<!-- full docs sitemap band: every section reachable from the landing -->
	<section class="lp-next" aria-label={t('Documentation map', '문서 맵', '文档地图')}>
		<h2>{t('Explore the docs', '문서 살펴보기', '浏览文档')}</h2>
		<div class="lp-next-grid">
			{docsMap.map((group) => (
				<div class="lp-next-col">
					<h3><svg class="lp-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={icons[group.icon]} /></svg>{group.label}</h3>
					<ul>
						{group.links.map((link) => (
							<li><a href={link.href}>{link.label}</a></li>
						))}
					</ul>
				</div>
			))}
		</div>
	</section>

	<p class="lp-disclaimer">
		{t(
			'opencodex is an independent community project, not affiliated with or endorsed by OpenAI, Anthropic, or any other provider. Some providers may restrict accounts that route traffic through third-party proxies — review each provider\u2019s Terms of Service before connecting.',
			'opencodex는 독립 커뮤니티 프로젝트이며 OpenAI, Anthropic 등 어떤 프로바이더와도 제휴하거나 보증받지 않습니다. 일부 프로바이더는 서드파티 프록시 경유 트래픽 계정을 제한할 수 있으니 연결 전 각 프로바이더의 이용약관을 확인하세요.',
			'opencodex 是独立的社区项目，与 OpenAI、Anthropic 或任何其他 provider 均无关联或背书。部分 provider 可能限制经第三方代理路由流量的账号 —— 连接前请查阅各 provider 的服务条款。'
		)}
	</p>
</div>

<script>
	// Frame-sequence scrub (motion.md): the demo capture plays through as the
	// scrub scene scrolls. Short-circuits under reduced motion / small screens
	// (the animated poster stays); progressive checkpoint loading.
	const canvas = document.querySelector<HTMLCanvasElement>('.lp-scrub-canvas');
	const section = document.querySelector<HTMLElement>('.lp-scene-scrub');
	const poster = document.querySelector<HTMLImageElement>('.lp-scrub-poster');
	const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
	const wide = matchMedia('(min-width: 48rem)').matches;
	if (canvas && section && poster && !reduce && wide) {
		const ctx = canvas.getContext('2d');
		const count = Number(canvas.dataset.count || '0');
		const base = canvas.dataset.base || '/';
		const url = (i: number) => `${base}demo-frames/${String(i + 1).padStart(3, '0')}.webp`;
		const frames: (HTMLImageElement | undefined)[] = new Array(count);
		let started = false;
		let current = -1;
		let raf = 0;
		const load = (i: number) =>
			new Promise<void>((resolve) => {
				if (frames[i]) return resolve();
				const img = new Image();
				img.onload = () => { frames[i] = img; resolve(); };
				img.onerror = () => resolve();
				img.src = url(i);
			});
		const nearestLoaded = (i: number) => {
			for (let d = 0; d < count; d++) {
				if (frames[i - d]?.complete) return i - d;
				if (frames[i + d]?.complete) return i + d;
			}
			return -1;
		};
		const draw = (i: number) => {
			const j = nearestLoaded(Math.max(0, Math.min(count - 1, i)));
			if (j < 0 || j === current || !ctx) return;
			current = j;
			const img = frames[j]!;
			if (canvas.width !== img.naturalWidth) {
				canvas.width = img.naturalWidth;
				canvas.height = img.naturalHeight;
			}
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
			poster.style.display = 'none';
			canvas.style.display = 'block';
		};
		const update = () => {
			raf = 0;
			const rect = section.getBoundingClientRect();
			const travel = section.offsetHeight - innerHeight;
			if (travel <= 0) return;
			const progress = Math.min(1, Math.max(0, -rect.top / travel));
			draw(Math.round(progress * (count - 1)));
		};
		const start = async () => {
			if (started) return;
			started = true;
			await load(0);
			draw(0);
			// checkpoints first, then fill in idle time
			const checkpoints = [count - 1, Math.floor(count / 2), Math.floor(count / 4), Math.floor((3 * count) / 4)];
			await Promise.all(checkpoints.map(load));
			update();
			const fill = (i: number) => {
				if (i >= count) return;
				load(i).then(() => {
					const next = () => fill(i + 1);
					'requestIdleCallback' in window ? requestIdleCallback(next) : setTimeout(next, 16);
				});
			};
			fill(0);
			addEventListener('scroll', () => { raf ||= requestAnimationFrame(update); }, { passive: true });
			addEventListener('resize', () => { raf ||= requestAnimationFrame(update); }, { passive: true });
		};
		new IntersectionObserver((entries, obs) => {
			if (entries.some((e) => e.isIntersecting)) { obs.disconnect(); start(); }
		}, { rootMargin: '100% 0px' }).observe(section);
	}
</script>
